# Supabase (client) — publishable/anon key is public-safe, protected by RLS
VITE_SUPABASE_PROJECT_ID="suwaetnsszlpaaykhpif"
VITE_SUPABASE_URL="https://suwaetnsszlpaaykhpif.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx"

# Stripe (client) — publishable token (pk_test_... or pk_live_...)
VITE_PAYMENTS_CLIENT_TOKEN="pk_test_xxxxxxxxxxxxxxxxxxxxxxxx"

# Mapbox (client) — public token (pk....) used by VenueMap
VITE_MAPBOX_TOKEN="pk.xxxxxxxxxxxxxxxxxxxxxxxx"

# Feature flags — postcode-to-nearest-venue finder (paid geocoding provider).
# Commercially unapproved; MUST stay false/unset until signed off (blocker Q16).
VITE_ENABLE_POSTCODE_VENUE_FINDER="false"

# Stripe Connect — The Dance Exclusive's CONNECTED account id (acct_...).
# Required when VITE_PAYMENTS_CLIENT_TOKEN is the Nullshift PLATFORM publishable
# key: the Payment Element must be bound to the connected account that owns the
# charges. Leave unset for pre-Connect (single-account) mode.
VITE_STRIPE_CONNECTED_ACCOUNT="acct_xxxxxxxxxxxxxxxx"
